{
  "name": "zuozizhen-tanstack-start",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "content:build": "node scripts/build-content.mjs",
    "dev": "vp dev",
    "build": "vp build",
    "start": "vp preview",
    "check": "vp check",
    "test": "vp test --config vite.test.config.ts",
    "deploy": "node scripts/prepare-cloudflare-config.mjs && vp build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply zuozizhen --local",
    "db:migrate": "wrangler d1 migrations apply zuozizhen --remote",
    "lint": "vp lint"
  },
  "dependencies": {
    "@hotwired/stimulus": "3.2.2",
    "@tanstack/react-router": "1.170.11",
    "@tanstack/react-start": "1.168.20",
    "drizzle-orm": "0.45.2",
    "isbot": "5.1.32",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.40.0",
    "@cloudflare/workers-types": "4.20260605.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "24.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "0.31.10",
    "gray-matter": "4.0.3",
    "marked": "17.0.1",
    "node-addon-api": "8.5.0",
    "node-gyp": "12.1.0",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "4.98.0"
  },
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "0.34.5",
    "@img/sharp-libvips-darwin-arm64": "1.2.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.16.0"
}
